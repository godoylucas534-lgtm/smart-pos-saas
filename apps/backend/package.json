{
    "name": "pos-backend",
    "version": "1.0.0",
    "private": true,
    "scripts": {
        "clean:dist": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true,maxRetries:5,retryDelay:100})\"",
        "build": "npm run clean:dist && nest build",
        "start": "node dist/main",
        "start:dev": "nest start --watch",
        "start:debug": "nest start --debug --watch",
        "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
        "test": "npx jest --passWithNoTests",
        "test:watch": "npx jest --watch",
        "test:cov": "npx jest --coverage",
        "test:e2e": "npx jest --runInBand --config ./test/jest-e2e.json",
        "migration:generate": "typeorm migration:generate -d src/config/data-source.ts",
        "migration:run": "typeorm migration:run -d src/config/data-source.ts",
        "migration:revert": "typeorm migration:revert -d src/config/data-source.ts",
        "schema:drop": "typeorm schema:drop -d src/config/data-source.ts",
        "seed": "ts-node -r tsconfig-paths/register src/database/seeds/run-seeds.ts"
    },
    "jest": {
        "testPathIgnorePatterns": [
            "\\\\node_modules\\\\",
            "\\\\dist\\\\"
        ],
        "modulePathIgnorePatterns": [
            "<rootDir>/dist/"
        ],
        "watchPathIgnorePatterns": [
            "<rootDir>/dist/"
        ]
    },
    "dependencies": {
        "@nestjs/common": "^10.3.0",
        "@nestjs/config": "^3.1.1",
        "@nestjs/core": "^10.3.0",
        "@nestjs/jwt": "^10.2.0",
        "@nestjs/mapped-types": "^2.1.1",
        "@nestjs/passport": "^10.0.3",
        "@nestjs/platform-express": "^10.3.0",
        "@nestjs/throttler": "^6.5.0",
        "@nestjs/typeorm": "^10.0.1",
        "bcryptjs": "^2.4.3",
        "class-transformer": "^0.5.1",
        "class-validator": "^0.14.1",
        "helmet": "^8.2.0",
        "passport": "^0.7.0",
        "passport-jwt": "^4.0.1",
        "passport-local": "^1.0.0",
        "pg": "^8.11.3",
        "reflect-metadata": "^0.2.1",
        "rxjs": "^7.8.1",
        "typeorm": "^0.3.19",
        "uuid": "^9.0.1"
    },
    "devDependencies": {
        "@nestjs/cli": "^10.4.9",
        "@nestjs/schematics": "^10.1.0",
        "@nestjs/testing": "^10.3.0",
        "@types/bcryptjs": "^2.4.6",
        "@types/express": "^4.17.21",
        "@types/jest": "^29.5.11",
        "@types/node": "^20.11.5",
        "@types/passport-jwt": "^4.0.1",
        "@types/passport-local": "^1.0.38",
        "@types/uuid": "^9.0.7",
        "@typescript-eslint/eslint-plugin": "^6.19.0",
        "@typescript-eslint/parser": "^6.19.0",
        "eslint": "^8.56.0",
        "jest": "^29.7.0",
        "ts-jest": "^29.1.2",
        "ts-node": "^10.9.2",
        "tsc-alias": "^1.8.17",
        "tsconfig-paths": "^4.2.0",
        "typescript": "^5.3.3"
    }
}
