NODE_ENV=development
PORT=3000

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=sistema_local
POSTGRES_SSL=false
DB_LOGGING=false

JWT_SECRET=replace_with_secure_random_secret
JWT_EXPIRES_IN=7d

# Comma-separated origins for CORS in production
# Example: https://app.tu-dominio.com,https://www.tu-dominio.com
FRONTEND_URLS=http://localhost:5173
